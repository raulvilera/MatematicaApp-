rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Usuário lê a si mesmo, ou alunos podem ler o professor, ou professor lê seus alunos
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        resource.data.role == 'teacher' || 
        resource.data.teacherId == request.auth.uid
      );
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Apenas o backend escreve pagamentos
      }
    }

    match /invites/{inviteCode} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
    }

    match /progress/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.teacherId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
    }
  }
}

